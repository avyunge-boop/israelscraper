{
  "name": "@workspace/scraper",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "hello": "tsx ./src/hello.ts",
    "start:server": "tsx ./src/server.ts",
    "scrape-bus-alerts": "tsx ./src/scrape-bus-alerts.ts",
    "scrape-bus-alerts:refresh": "tsx ./src/scrape-bus-alerts.ts --refresh",
    "scrape-bus-alerts:full": "tsx ./src/scrape-bus-alerts.ts --full-scan",
    "scan": "tsx ./src/orchestrator.ts",
    "scan:metropoline": "tsx ./src/orchestrator.ts -- --agency=metropoline",
    "scan:kavim": "tsx ./src/orchestrator.ts -- --agency=kavim",
    "build:orchestrator-bundle": "esbuild src/orchestrator.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/orchestrator.mjs --packages=external",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test-groq": "tsx ./src/test-groq.ts",
    "consolidate-data": "tsx ./src/consolidate-nested-data.ts"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.17.3",
    "express": "^4.21.2",
    "groq-sdk": "^0.15.0",
    "dotenv": "^16.4.7",
    "nodemailer": "^6.10.1",
    "p-limit": "^6.2.0",
    "puppeteer": "^23.0.0",
    "tsx": "catalog:"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "@types/express": "^4.17.21",
    "@types/node": "catalog:",
    "@types/nodemailer": "^6.4.17"
  }
}
