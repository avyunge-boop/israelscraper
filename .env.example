# Copy to `.env` at the repository root (never commit `.env`).
# For the dashboard: you can also use `b_UUco9SpqaeI/.env.local` (loaded by Next).
#
# Packaged macOS app (Israel Scraper.app): put the same keys in
#   ~/Library/Application Support/Israel Scraper/config.env
# (same KEY=value lines). The Electron shell loads that file into the Next server process.

GROQ_API_KEY=
GROQ_MODEL=

BUS_ALERTS_SMTP_HOST=
BUS_ALERTS_SMTP_PORT=
BUS_ALERTS_SMTP_SECURE=
BUS_ALERTS_SMTP_USER=
BUS_ALERTS_SMTP_PASS=
BUS_ALERTS_EMAIL_FROM=
BUS_ALERTS_EMAIL_TO=

PUPPETEER_EXECUTABLE_PATH=
CHROME_PATH=

EGGED_ALERTS_URL=
DAN_ALERTS_URL=
KAVIM_ALERTS_URL=
METROPOLINE_ALERTS_URL=

SCRAPER_ORCHESTRATOR_SKIP_ALL_EMAIL=
# Dashboard (Next): URL of the scraper HTTP service when not colocated (e.g. Cloud Run). Enables POST /run-scrape and GET /data/*.
SCRAPER_API_URL=
AI_SUMMARIES_JSON_PATH=
