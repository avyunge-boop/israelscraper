# Copy to `.env` at the repository root (never commit `.env`).
# For the dashboard: use `b_UUco9SpqaeI/.env.local` for secrets (loaded after this file). Empty
# `KEY=` lines in `.env` do not block values from `.env.local` (see `b_UUco9SpqaeI/next.config.mjs`).
#
# Packaged macOS app (Israel Scraper.app): put the same keys in
#   ~/Library/Application Support/Israel Scraper/config.env
# (same KEY=value lines). The Electron shell loads that file into the Next server process.

# Required for AI summaries (Egged path), /api/translate, and health-check Groq ping.
# On Cloud Run / Docker image, set in the service env — .env.local is not in the container.
GROQ_API_KEY=
GROQ_MODEL=
# Max new Groq summaries per dashboard load (0 = unlimited). Protects rate limits.
GROQ_MAX_SUMMARIES_PER_REQUEST=

BUS_ALERTS_SMTP_HOST=
BUS_ALERTS_SMTP_PORT=
BUS_ALERTS_SMTP_SECURE=
BUS_ALERTS_SMTP_USER=
BUS_ALERTS_SMTP_PASS=
BUS_ALERTS_EMAIL_FROM=
BUS_ALERTS_EMAIL_TO=

PUPPETEER_EXECUTABLE_PATH=
CHROME_PATH=

# Bus Nearby: re-fetch alerts per route if last scan older than this many hours (default 24). Not link discovery.
BUSNEARBY_SCAN_STALE_AFTER_H=

EGGED_ALERTS_URL=
DAN_ALERTS_URL=
KAVIM_ALERTS_URL=
METROPOLINE_ALERTS_URL=

SCRAPER_ORCHESTRATOR_SKIP_ALL_EMAIL=
# Dashboard (Next): URL of the scraper HTTP service when not colocated (e.g. Cloud Run). Enables POST /run-scrape and GET /data/*.
SCRAPER_API_URL=
AI_SUMMARIES_JSON_PATH=
